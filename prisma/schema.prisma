generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql" // or "postgresql", etc.
}

model Mix {
  id     String @id @default(cuid())
  artist String

  // we only need the artist name for each mix now; the title field was
  // removed as part of simplifying the data model. existing migrations
  // include the column but future runs will drop it.

  votes Vote[]
}

model Vote {
  id String @id @default(cuid())

  email           String
  emailNormalized String
  name            String
  city            String
  zipcode         String

  country      Country
  otherCountry String?

  mixId String
  mix   Mix    @relation(fields: [mixId], references: [id], onDelete: Cascade)

  ipHash    String
  createdAt DateTime @default(now())

  @@unique([emailNormalized])
  @@index([ipHash])
  @@index([mixId])
}

enum Country {
  BELGIUM
  OTHER
}
